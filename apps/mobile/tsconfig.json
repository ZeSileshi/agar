{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ES2022"],
    "jsx": "react-native",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@agar/shared/*": ["../../packages/shared/src/*"],
      "@agar/i18n/*": ["../../packages/i18n/src/*"]
    }
  },
  "include": ["src/**/*", "app.json"],
  "exclude": ["node_modules"]
}
