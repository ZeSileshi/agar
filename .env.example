# ============================================================
# Agar (አጋር) Environment Variables
# Copy to .env and fill in values
# ============================================================

NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# Database (PostgreSQL with PostGIS)
DATABASE_URL=postgresql://agar:agar_dev_password@localhost:5432/agar_dev

# Redis (cache, queues, sessions)
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - Apple
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# OAuth - Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# File Storage (S3 or Cloudflare R2)
S3_BUCKET=agar-uploads-dev
S3_REGION=us-east-1
S3_ENDPOINT=                          # Leave empty for AWS S3, set for R2/MinIO
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ML Service
ML_SERVICE_URL=http://localhost:8000

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@agar.app

# Push Notifications (Expo)
EXPO_ACCESS_TOKEN=

# Monitoring
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Image Moderation (optional at dev time)
MODERATION_API_KEY=

# Logging
LOG_LEVEL=debug                       # debug | info | warn | error
